@model List<Book>
@{
    ViewData["Title"] = "Danh sách sách";
    var search = ViewBag.Search as string ?? "";
    var sortBy = ViewBag.SortBy as string ?? "Id";
    var sortOrder = ViewBag.SortOrder as string ?? "asc";
    string SortLink(string column) {
        var newOrder = sortBy == column && sortOrder == "asc" ? "desc" : "asc";
        return Url.Action("Index", new { search, sortBy = column, sortOrder = newOrder })!;
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Danh sách sách (SQL Server)</h2>
    <a asp-action="Create" class="btn btn-primary">+ Thêm sách</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-auto flex-grow-1">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm kiếm theo tên sách..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Tìm kiếm</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Xóa bộ lọc</a>
        }
    </div>
</form>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        <p class="mb-0">Chưa có dữ liệu sách trong CSDL.</p>
    </div>
}
else
{
    <p class="text-muted">Danh sách có @Model.Count cuốn sách.</p>

    <div class="table-responsive">
        <table class="table align-middle table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px;">Id</th>
                    <th style="width:120px;">Ảnh</th>
                    <th>Tên sách</th>
                    <th>Tác giả</th>
                    <th style="width:140px; text-align:center;">Giá</th>
                    <th style="width:100px; text-align:center;">SL</th>
                    <th style="width:220px; text-align:center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{ var idx = 0; }
                @foreach (var item in Model)
                {
                    idx++;
                    <tr>
                        <td class="text-center">@idx</td>
                        <td>
                            @{
                                var imgSrc = (item.Images != null && item.Images.Count > 0) ? "/" + item.Images[0].FileName : "/images/giao-dien-sach.png";
                            }
                            <img src="@imgSrc" alt="@item.Title" class="book-thumb" onerror="this.src='/images/giao-dien-sach.png'" />
                        </td>
                        <td>@item.Title</td>
                        <td>@(item.Author?.Name ?? "—")</td>
                        <td class="text-center">@item.Price.ToString("N0") đ</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-center">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-white me-1">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>console.log("Trang danh sách sách đã được tải");</script>
}
