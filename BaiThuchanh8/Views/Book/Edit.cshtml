@model Book
@{
    ViewData["Title"] = "Sửa sách";
}

<h2>Sửa thông tin sách</h2>

@if (Model.Images != null && Model.Images.Any())
{
    <div class="mb-3">
        <label class="form-label">Ảnh hiện tại</label>
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var img in Model.Images)
            {
                <div class="border rounded p-2">
                    <img src="@img.ImagePath" alt="Ảnh sản phẩm" style="height:120px; width:120px; object-fit:cover;" />
                    <form asp-action="DeleteImage" method="post" class="mt-2" onsubmit="return confirm('Xóa ảnh này?');">
                        <input type="hidden" name="imageId" value="@img.Id" />
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa ảnh</button>
                    </form>
                </div>
            }
        </div>
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Author" class="form-label"></label>
        <input asp-for="Author" class="form-control" />
        <span asp-validation-for="Author" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" for="imageFiles">Thêm hình sản phẩm (JPG hoặc PNG)</label>
        <input id="imageFiles" type="file" name="imageFiles" accept=".jpg,.jpeg,.png,image/jpeg,image/png" class="form-control" multiple />
        <span class="text-danger">@Html.ValidationMessage("imageFiles")</span>
    </div>

    <button type="submit" class="btn btn-warning">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
