@model List<Student>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2 class="page-title">Danh sách sinh viên</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="toolbar mb-3">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Tìm kiếm</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                   placeholder="Tên, email hoặc số điện thoại..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sắp xếp theo</label>
            <select name="sortBy" asp-items="ViewBag.SortByList" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Thứ tự</label>
            <select name="sortOrder" asp-items="ViewBag.SortOrderList" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Lọc</button>
        </div>
    </form>
</div>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm mới</a>
</p>

@if (Model.Count == 0)
{
    <p class="text-muted">Chưa có dữ liệu</p>
}
else
{
    <p class="text-muted">Danh sách có @Model.Count sinh viên</p>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        console.log("Trang danh sách sinh viên đã được tải");
    </script>
}
