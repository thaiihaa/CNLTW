@model Book
@{
    ViewData["Title"] = "Chi tiết sách";
}

<h2>Chi tiết sách</h2>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Tên sách</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Tác giả</dt>
    <dd class="col-sm-9">@Model.Author</dd>

    <dt class="col-sm-3">Giá</dt>
    <dd class="col-sm-9">@Model.Price.ToString("N0") đ</dd>

    <dt class="col-sm-3">Số lượng</dt>
    <dd class="col-sm-9">@Model.Quantity</dd>

    <dt class="col-sm-3">Mô tả</dt>
    <dd class="col-sm-9">@(Model.Description ?? "—")</dd>
    <dt class="col-sm-3">Ảnh</dt>
    <dd class="col-sm-9">
        @if (Model.Images != null && Model.Images.Any())
        {
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var img in Model.Images)
                {
                    <img src="@img.ImagePath" alt="Ảnh" style="max-height:200px" />
                }
            </div>
        }
        else
        {
            <span class="text-muted">(Chưa có ảnh)</span>
        }
    </dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
