@model KiemTraGiuaKi.Models.Dish_BIT242377

@{
    ViewData["Title"] = "Xóa món ăn";
}

<h1>Xóa món ăn</h1>

<h3>Bạn có chắc muốn xóa món ăn "@Model.Name"?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Loại món ăn</dt>
        <dd class="col-sm-10">@Model.DishCategory?.Name</dd>

        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0") VNĐ</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>
